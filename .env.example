# Prova Observer deployment configuration
# Copy to .env and fill in values.

# Public URL of this prova-observer deployment (used in agent context for examples)
PROVA_API_URL=https://your-deployment.example.com

# Server port
PROVA_SERVER_PORT=17824

# Network preset: anvil | base-sepolia | base
PROVA_NETWORK=anvil

# Base RPC endpoint
# Local anvil:        http://host.docker.internal:8545
# Base Sepolia:       https://sepolia.base.org
# Base mainnet:       https://mainnet.base.org
PROVA_RPC_URL=http://host.docker.internal:8545

# Optional: WebSocket endpoint for live streaming. Some providers (Alchemy,
# Infura) want a separate URL for ws.
# PROVA_WS_URL=wss://base-mainnet.g.alchemy.com/v2/<key>

# Prova v2 contract addresses on the active network. The repo ships the
# anvil deterministic addresses by default; override per-environment.
PROVA_CONTRACT_PROVA_TOKEN=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
PROVA_CONTRACT_PROOF_VERIFIER=0x5FC8d32690cc91D4c39d9d3abcBD16989F875707
PROVA_CONTRACT_PROVER_REGISTRY=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
PROVA_CONTRACT_PROVER_STAKING=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
PROVA_CONTRACT_CONTENT_REGISTRY=0xDc64a140Aa3E981100a9becA4E685f962f0cF6C9
PROVA_CONTRACT_STORAGE_MARKETPLACE=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853
PROVA_CONTRACT_FEE_ROUTER=0x0165878A594ca255338adfa4d48449f69242Eb8F
PROVA_CONTRACT_PROVER_REWARDS=0x610178dA211FEF7D417bC0e6FeD39F05609AD788

# Postgres for the Ponder indexer.
DATABASE_URL=postgres://ponder:ponder@localhost:17826/ponder

# Optional: BetterStack ClickHouse credentials for the optional logging
# pipeline tools. Leave blank to disable.
BETTERSTACK_CH_USER=
BETTERSTACK_CH_PASSWORD=
