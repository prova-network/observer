{
  "name": "prova-network-observer-indexer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ponder dev",
    "start": "ponder start",
    "codegen": "ponder codegen",
    "generate-abis": "bash ../scripts/generate-abis.sh",
    "typecheck": "node -e \"require('node:fs').symlinkSync('ponder.config.anvil.ts', 'ponder.config.ts')\" 2>/dev/null; PROVA_RPC_URL=http://localhost:1234 DATABASE_URL=postgres://noop:noop@localhost:5432/noop ponder codegen && tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.5",
    "multiformats": "^13",
    "ponder": "npm:@rvagg/ponder@^0.16.6",
    "viem": "^2.48"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7"
  },
  "description": "Ponder-based indexer for Prova Network smart contracts on Base."
}
