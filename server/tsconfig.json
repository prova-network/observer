{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",

    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,

    "target": "ESNext",
    "lib": ["ESNext"],
    "moduleDetection": "force",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "esModuleInterop": true,

    "strict": true,
    "noImplicitOverride": true,

    "skipLibCheck": true
  },
  "include": ["src"]
}
